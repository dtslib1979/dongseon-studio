{
  "$schema": "pipeline-flow.v1.0",
  "$dummy": true,

  "stages": [
    {
      "id": "S1",
      "name": "PRODUCT_CARD 작성",
      "input": "수동 입력",
      "output": "catalog/products/PROD-XXX/card.json",
      "executor": "human",
      "status": "active"
    },
    {
      "id": "S2",
      "name": "AI 에셋 생성",
      "input": "card.json",
      "output": "content/{models,webtoon,cad,fantasy}/",
      "executor": "parksy-image",
      "depends_on": ["S1"],
      "status": "not_implemented"
    },
    {
      "id": "S3",
      "name": "GPU 렌더링",
      "input": "content/",
      "output": "{coupang,naver}/rendered/, youtube/rendered/",
      "executor": "gpu/",
      "depends_on": ["S2"],
      "status": "not_implemented"
    },
    {
      "id": "S4a",
      "name": "쿠팡 등록",
      "input": "coupang/rendered/",
      "output": "card.json → channels.coupang.url",
      "executor": "automation/adapters/coupang.js",
      "depends_on": ["S3"],
      "status": "not_implemented"
    },
    {
      "id": "S4b",
      "name": "네이버 등록",
      "input": "naver/rendered/",
      "output": "card.json → channels.naver.url",
      "executor": "automation/adapters/naver.js",
      "depends_on": ["S3"],
      "status": "not_implemented"
    },
    {
      "id": "S4c",
      "name": "YouTube 업로드",
      "input": "youtube/rendered/",
      "output": "card.json → channels.youtube.video_id",
      "executor": "automation/adapters/youtube.js",
      "depends_on": ["S3"],
      "status": "not_implemented"
    },
    {
      "id": "S4d",
      "name": "쇼룸 배포",
      "input": "showroom/",
      "output": "card.json → channels.showroom.page",
      "executor": "automation/adapters/showroom.js",
      "depends_on": ["S3"],
      "status": "not_implemented"
    },
    {
      "id": "S5",
      "name": "매출 데이터 수집",
      "input": "4채널 판매 데이터",
      "output": "analytics/*.jsonl",
      "executor": "scripts/generate-report.sh",
      "depends_on": ["S4a", "S4b", "S4c", "S4d"],
      "status": "not_implemented"
    },
    {
      "id": "S6",
      "name": "루프백 (다음 PRODUCT_CARD)",
      "input": "analytics/*.jsonl",
      "output": "다음 PRODUCT_CARD 기획",
      "executor": "human + style_module(V-F-C-D)",
      "depends_on": ["S5"],
      "status": "not_implemented"
    }
  ]
}
